{
  "name": "@gamemaster/control-plane",
  "version": "1.0.0",
  "description": "Payload CMS control plane and public frontend for the GameMaster migration stack",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build --webpack",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --no-server-fast-refresh",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "bootstrap": "cross-env NODE_OPTIONS=--no-deprecation node --import=tsx/esm src/scripts/bootstrap.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "npm run test:int && npm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "ci": "npm run generate:importmap && npm run generate:types && npm run build"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.7",
    "@payloadcms/db-postgres": "3.81.0",
    "@payloadcms/next": "3.81.0",
    "@payloadcms/richtext-lexical": "3.81.0",
    "@payloadcms/ui": "3.81.0",
    "@qdrant/js-client-rest": "^1.15.1",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cross-env": "^7.0.3",
    "graphql": "^16.8.1",
    "livekit-client": "^2.15.11",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^0.544.0",
    "next": "16.2.1",
    "openai": "^6.6.0",
    "payload": "3.81.0",
    "pdf-parse": "^1.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.2",
    "slugify": "^1.6.6",
    "typescript": "5.7.3",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@vitejs/plugin-react": "4.5.2",
    "dotenv": "^16.6.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.1",
    "jsdom": "28.0.0",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
